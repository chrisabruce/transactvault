# TransactVault environment configuration

# Server — ports avoid the usual suspects (3000/8000/9000) so TransactVault
# can coexist with whatever else you have running locally.
APP_NAME=TransactVault
BASE_URL=http://localhost:37420
HOST=0.0.0.0
PORT=37420
PRETTY_LOGS=true
RUST_LOG=info,transactvault=debug

# SurrealDB
#   - surrealkv://./surreal-data/tv.db   embedded, file-backed (recommended dev)
#   - rocksdb://./surreal-data/tv.db     embedded, RocksDB backend
#   - mem://                             ephemeral, in-process (fastest tests)
#   - ws://127.0.0.1:37422               remote server (docker compose)
SURREAL_URL=surrealkv://./surreal-data/tv.db
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=transactvault
SURREAL_DB=app

# JWT — change in production! 64+ character random string recommended.
JWT_SECRET=change-me-to-a-long-random-secret-please-please-please
JWT_EXPIRY_HOURS=168

# Super-admins — comma-separated emails granted /admin/* access. Anyone
# whose login email is in this list gets the cross-brokerage user list and
# the audit log. Leave blank to disable the admin panel entirely.
SUPERADMIN_EMAILS=

# Email-verification window. New signups have this many hours to click the
# verify link before it expires.
VERIFICATION_EXPIRY_HOURS=24

# Anti-abuse on the /signup form:
#   POW_DIFFICULTY_BITS — number of leading zero bits the browser must
#     find. 18 ≈ 0.5–2 s of work for honest users, scales sub-linearly
#     for spam scripts. Set to 0 to disable PoW (handy in tests).
POW_DIFFICULTY_BITS=18

# Per-IP rate limits. Bursts are allowed up to the cap, refill at the
# corresponding rate. Tune up if legit traffic bumps these.
SIGNUP_RATE_PER_HOUR=5
LOGIN_RATE_PER_QH=20

# Document storage — RustFS (S3-compatible). For local development run the
# rustfs container via `docker compose up rustfs` and use the defaults below.
RUSTFS_ENDPOINT=http://127.0.0.1:37421
RUSTFS_REGION=us-east-1
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=transactvault

# Transactional email via Resend. Leave RESEND_API_KEY blank to disable
# delivery during development — outbound messages will be logged instead.
RESEND_API_KEY=
RESEND_FROM=TransactVault <no-reply@transactvault.example>
RESEND_REPLY_TO=
